# LLM mode: "api" = Groq (default) | "local" = Ollama
LLM_MODE=api

# Groq (get free key at console.groq.com) — used when LLM_MODE=api
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (install from ollama.com, then: ollama pull gemma4:e2b) — used when LLM_MODE=local
OLLAMA_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Research - Tavily (get free key at tavily.com)
TAVILY_API_KEY=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=          # format: urn:li:person:XXXXXXXX

# X / Twitter
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
